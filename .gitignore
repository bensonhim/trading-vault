# Obsidian workspace (user-specific, changes frequently)
.obsidian/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temp files
*.tmp
*.swp
*~

# Microsoft Word lock files (temporary, created when doc is open)
# These should NEVER be committed
~$*.doc*
~*.tmp

# Python cache / build artifacts
__pycache__/
*.pyc
*.pyo

# Node modules (if any JS tooling added later)
node_modules/

# Build outputs
dist/
build/

# Local development
.env
.env.local

# Word temp files
*.wbk
*.tmp

# Backup files
*.bak
*.old
